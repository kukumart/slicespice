rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model combined with role-based access control 
     * facilitated by structural segregation. It prioritizes "Authorization Independence," 
     * where a user's role is stored directly on their profile for performance, while 
     * administrative privileges are verified via a dedicated /roles_admin/ collection.
     *
     * DATA STRUCTURE
     * - /users/{userId}: Primary user profile data. Access limited to owner and admins.
     * - /roles_admin/{userId}: Administrative flag collection. Presence = Admin status.
     * - /orders/{orderId}: Customer orders. Owners can read/create. Admins can manage all.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the request is from an authenticated user (includes Anonymous).
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user has administrative privileges.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == userId;
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      /**
       * @description Allows users to read their own admin status to facilitate UI logic.
       * Admin management is restricted to existing admins.
       */
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      /**
       * @description Rules for the Orders collection. 
       * Users can create orders and read their own.
       * Admins have full access to manage the order stream.
       */
      allow create: if isSignedIn(); // Allows both registered and guest users to order
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin(); // Only admins can see the full list
      allow update: if isAdmin(); // Only admins can update status in the dashboard
      allow delete: if isAdmin();
    }

  }
}
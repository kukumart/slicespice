
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store user-specific information and delivery preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer food order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "qty": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["placed", "preparing", "on-the-way", "delivered"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryAddress": { "type": "string" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order history"
    }
  }
}
